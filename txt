                        <!-- -->
                        <code style="font-size:13px">onAllReady</code>
                        把本次解析结果写入
                        <!-- -->
                        <code style="font-size:13px">window.__DASHBOARD__</code>
                        ，hydrate 时<strong>首屏 0 次</strong>
                        <code style="font-size:13px">/api</code>
